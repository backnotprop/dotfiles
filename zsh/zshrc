# Powerlevel10k instant prompt
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export PATH="${HOME}/bin:${PATH}"

# fnm (Node version manager)
eval "$(fnm env --use-on-cd)"

# pipx
export PATH="$PATH:$HOME/.local/bin"

# Powerlevel10k
[[ -f ~/powerlevel10k/powerlevel10k.zsh-theme ]] && source ~/powerlevel10k/powerlevel10k.zsh-theme
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh


# History
export HISTSIZE=1000000000
export SAVEHIST=1000000000
export HISTFILE=~/.zsh_history
setopt SHARE_HISTORY APPEND_HISTORY INC_APPEND_HISTORY EXTENDED_HISTORY
alias history='history 0'

# Claude
alias cx='claude --dangerously-skip-permissions'
alias cc='claude --continue --dangerously-skip-permissions'
alias cg='claude --dangerously-skip-permissions "Gain a complete end-to-end understanding of the system for any backend component or app or server, all the way through the frontend and how data flows between"'
cgp() {
  claude --dangerously-skip-permissions "$*"
}

# Dotfiles
source "$HOME/dotfiles/macos/ensure-defaults.sh"
source "$HOME/dotfiles/worktree/worktree.sh"
alias theme="$HOME/dotfiles/ghostty/toggle-theme.sh"
